{
  "name": "nasne-wrapper",
  "version": "2.0.0",
  "description": "A simple wrapper for nasne API.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mtane0412/nasne-wrapper.git"
  },
  "author": "mtane0412",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  }
}
